{
  "manifest_version": 3,
  "name": "VS Code VSIX Downloader",
  "version": "1.0.0",
  "description": "Download VSIX files directly from the Visual Studio Marketplace.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://marketplace.visualstudio.com/items*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
